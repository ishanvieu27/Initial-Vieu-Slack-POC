# OpenAI API key — powers the conversational AI in threads and intro drafts
OPENAI_API_KEY=sk-...

# Slack app credentials (create app at https://api.slack.com/apps)
# Scopes: chat:write, im:write, im:history, commands, users:read, users:read.email,
# app_mentions:read, groups:write, groups:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Only needed for LOCAL dev (src/app.js runs Socket Mode so you don't need a
# public URL). The deployed Vercel function (api/slack/events.js) runs HTTP
# mode instead and does NOT use this — leave it unset in Vercel's env vars.
SLACK_APP_TOKEN=xapp-...

# Vercel KV (Upstash Redis) — backs state.json/activity.json/thread-memory,
# since Vercel's filesystem isn't writable or shared across invocations.
# Auto-populated in Vercel's dashboard once you provision + link a KV store.
# For local dev against the SAME store: `vercel env pull .env` after linking.
KV_REST_API_URL=...
KV_REST_API_TOKEN=...

# OPTIONAL. Locks the DM message handler to a single user's ID — useful for
# local testing when only you should be able to talk to the bot. Leave unset
# in a shared demo env so any tester in the workspace can drive the bot.
# Each caller of /vieu-fire is automatically their own AE (DMs go to the caller).
# AE_SLACK_ID=U0000000000

# Link shown in "See all in Vieu →" footer
VIEU_APP_URL=https://vieu.com/connections

# Intro approval/completion reminder spacing, in seconds. Two reminders fire at
# T and 2T. Default 172800 (2 days). Lower this to test reminders quickly.
INTRO_REMINDER_SECS=172800

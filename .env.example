# OpenAI API key — powers the conversational AI in threads and intro drafts
OPENAI_API_KEY=sk-...

# Slack app credentials (create app at https://api.slack.com/apps)
# Enable Socket Mode, add scopes: chat:write, im:write, commands, users:read, app_mentions:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# OPTIONAL. Locks the DM message handler to a single user's ID — useful for
# local testing when only you should be able to talk to the bot. Leave unset
# in a shared demo env so any tester in the workspace can drive the bot.
# Each caller of /vieu-fire is automatically their own AE (DMs go to the caller).
# AE_SLACK_ID=U0000000000

# Link shown in "See all in Vieu →" footer
VIEU_APP_URL=https://vieu.com/connections

# Intro approval/completion reminder spacing, in seconds. Two reminders fire at
# T and 2T. Default 172800 (2 days). Lower this to test reminders quickly.
INTRO_REMINDER_SECS=172800
